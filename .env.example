# ======================
# JSON2Video SaaS Config
# ======================

# Application
APP_NAME=JSON2Video
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_KEY=

# MySQL Database
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=json2video
DB_USERNAME=json2video
DB_PASSWORD=secret123

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# Queue
QUEUE_CONNECTION=redis

# Storage
STORAGE_PATH=/app/storage/renders
STORAGE_URL=http://localhost:8000/renders

# Video Defaults
DEFAULT_RESOLUTION=full-hd
DEFAULT_QUALITY=high
MAX_PAYLOAD_SIZE_MB=1
MAX_INPUT_ASSET_MB=500
MAX_OUTPUT_VIDEO_MB=2048

# Python Render Worker
RENDER_WORKER_CONCURRENCY=2
RENDER_TEMP_DIR=/tmp/renders

# phpMyAdmin
PMA_HOST=mysql
PMA_PORT=3306
